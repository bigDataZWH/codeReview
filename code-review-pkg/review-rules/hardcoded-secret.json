[
  {
    "id": "hardcoded-api-key",
    "name": "硬编码 API Key 检测",
    "severity": "high",
    "category": "security",
    "patterns": [
      { "type": "regex", "pattern": "(api[_-]?key|apikey)\\s*[:=]\\s*[\"'][A-Za-z0-9_\\-]{16,}[\"']", "message": "检测到硬编码 API Key，应从环境变量或密钥管理服务读取" },
      { "type": "regex", "pattern": "(aws[_-]?(access[_-]?key|secret[_-]?key))\\s*[:=]\\s*[\"'][A-Za-z0-9/+=]{16,}[\"']", "message": "检测到硬编码 AWS 密钥，存在泄露风险" }
    ]
  },
  {
    "id": "hardcoded-password",
    "name": "硬编码密码检测",
    "severity": "high",
    "category": "security",
    "patterns": [
      { "type": "regex", "pattern": "password\\s*[:=]\\s*[\"'][^\"']{4,}[\"']", "message": "检测到硬编码密码，应使用环境变量或凭据管理服务" },
      { "type": "regex", "pattern": "passwd\\s*[:=]\\s*[\"'][^\"']{4,}[\"']", "message": "检测到硬编码密码字段" },
      { "type": "contains_any", "items": ["password = \"", "password: \"", "passwd = \"", "pwd = \""], "message": "硬编码密码赋值，存在泄露风险" }
    ]
  },
  {
    "id": "hardcoded-token",
    "name": "硬编码 Token 检测",
    "severity": "high",
    "category": "security",
    "patterns": [
      { "type": "regex", "pattern": "(token|access[_-]?token|auth[_-]?token|bearer)\\s*[:=]\\s*[\"'][A-Za-z0-9_\\-\\.]{16,}[\"']", "message": "检测到硬编码 Token，应通过密钥管理服务获取" },
      { "type": "regex", "pattern": "(jwt|secret[_-]?key|private[_-]?key)\\s*[:=]\\s*[\"'][A-Za-z0-9_\\-]{16,}[\"']", "message": "检测到硬编码密钥/Token，存在泄露风险" }
    ]
  }
]
